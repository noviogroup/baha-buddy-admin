# ─── Supabase ────────────────────────────────────────────────────
# Same project as Baha Buddy V2 (Flutter app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin auth ──────────────────────────────────────────────────
# Server-side allowlist (authoritative). Used by withAdminAuth() in src/lib/admin-auth.ts.
# Comma-separated. Without this set, ALL authenticated users are admitted (dev mode).
ADMIN_EMAILS=valdez@noviogroup.com,admin@bahabuddy.app

# Client-side allowlist (legacy — used only for UX gating in AuthGate).
# Kept for compatibility; server-side ADMIN_EMAILS is the source of truth.
NEXT_PUBLIC_ADMIN_EMAILS=valdez@noviogroup.com,admin@bahabuddy.app

# ─── Stripe / Concierge Payments ─────────────────────────────────
# Used by POST /api/stripe/concierge-webhook to verify Stripe webhook signatures.
# Add the deployed admin webhook URL in Stripe and copy the whsec_ value here.
STRIPE_CONCIERGE_WEBHOOK_SECRET=whsec_your_concierge_webhook_secret

# Optional. Not required by the current webhook implementation because it uses
# the signed event payload, but keep this here if later admin needs Stripe lookups.
STRIPE_SECRET_KEY=sk_test_or_live_key

# ─── Email Notifications ─────────────────────────────────────────
# Current implementation uses Resend over fetch. If RESEND_API_KEY is missing,
# emails are skipped safely and webhook/order updates still complete.
RESEND_API_KEY=re_your_resend_key
MAIL_FROM=Baha Buddy <support@bahabuddy.com>
ADMIN_NOTIFICATION_EMAILS=ops@bahabuddy.com,admin@bahabuddy.com
WEB_APP_URL=https://bahabuddy.com

# ─── External links wired into the UI ───────────────────────────
# Header "Open Sanity Studio" button. Set to your Sanity Studio URL.
NEXT_PUBLIC_SANITY_STUDIO_URL=https://bahabuddy.sanity.studio

# Optional: link to Supabase logs from Edge Function Health page
NEXT_PUBLIC_SUPABASE_DASHBOARD_URL=https://supabase.com/dashboard/project/your-project-ref

# ─── LiteAPI / Travel Booking Provider ────────────────────────────
# Server-side only. Used by service health and future provider support tooling.
# Do not expose the private key with NEXT_PUBLIC_.
LITEAPI_API_KEY=your_live_liteapi_private_key
LITEAPI_PUBLIC_KEY=your_live_liteapi_public_key
TRAVEL_BOOKING_API_KEY=your_live_booking_provider_key
TRAVEL_BOOKING_API_BASE_URL=https://api.liteapi.travel/v3.0
TRAVEL_BOOKING_BOOK_BASE_URL=https://book.liteapi.travel/v3.0
TRAVEL_BOOKING_API_AUTH_HEADER=X-API-Key
